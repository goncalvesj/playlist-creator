# Frontend (used by Vite, prefixed with VITE_)
VITE_SPOTIFY_CLIENT_ID=YOUR_SPOTIFY_CLIENT_ID_HERE
VITE_SPOTIFY_REDIRECT_URI=http://127.0.0.1:5173/callback

# Backend settings are configured in:
# - api/local.settings.json (local dev, gitignored)
# - Azure Static Web Apps > Configuration > Application settings (production)
#
# Azure AI Foundry v1 Responses API:
# AZURE_OPENAI_TARGET_URI=
# AZURE_OPENAI_MODEL=
# AZURE_OPENAI_API_KEY=
# AZURE_OPENAI_API_VERSION=v1
#
# Optional API protection and cost controls:
# API_RATE_LIMIT_MAX_REQUESTS=5
# API_RATE_LIMIT_WINDOW_SECONDS=60
# API_RATE_LIMIT_MAX_CLIENTS=1000
# TRACKLIST_CACHE_TTL_SECONDS=21600
# TRACKLIST_CACHE_MAX_ENTRIES=100
# MAX_SOURCE_TEXT_CHARS=12000
# AZURE_OPENAI_MAX_OUTPUT_TOKENS=4000
