# Frontend (used by Vite, prefixed with VITE_)
VITE_SPOTIFY_CLIENT_ID=YOUR_SPOTIFY_CLIENT_ID_HERE
VITE_SPOTIFY_REDIRECT_URI=http://127.0.0.1:5173/callback

# Optional browser telemetry. Set this at build time for the deployed SWA.
VITE_APPLICATIONINSIGHTS_CONNECTION_STRING=
VITE_APPINSIGHTS_CLOUD_ROLE_NAME=playlist-creator-web
VITE_APP_ENVIRONMENT=development
VITE_APP_VERSION=local
VITE_BUILD_SHA=local
